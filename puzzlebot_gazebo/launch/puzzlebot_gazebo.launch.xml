<launch>
    <let name="world_path" value="$(find-pkg-share puzzlebot_gazebo)/worlds/maze.world"/>
   
    <arg name="use_sim_time" default="true"/>
    <arg name="headless" default="false"/>
    <arg name="x_pose" default="1.35"/>
    <arg name="y_pose" default="0.0"/>

    <include file="$(find-pkg-share puzzlebot_description)/launch/puzzlebot_description.launch.xml">
        <arg name="use_sim_time" value="$(var use_sim_time)"/>
        <arg name="rviz" value="false"/>
    </include>

    <include file="$(find-pkg-share gazebo_ros)/launch/gazebo.launch.py">
        <arg name="world" value="$(var world_path)"/>
        <arg name="verbose" value="true"/>
    </include>

    <node pkg="gazebo_ros" exec="spawn_entity.py" output="screen"
        args="-topic robot_description -entity puzzlebot -x $(var x_pose) -y $(var y_pose)"/>

</launch>
