<launch>
    <let name="world_path" value="$(find-pkg-share puzzlebot_gazebo)/worlds/maze.world"/>
    <let name="puzzlebot_description_path" value="$(find-pkg-share puzzlebot_description)/launch/puzzlebot_description.launch.xml" /> 
    <let name="gazebo_bridge_config_path" value="$(find-pkg-share puzzlebot_gazebo)/config/gazebo_bridge.yaml" /> 
    <let name="gz_sim_launch_path" value="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py" /> 
    
    <arg name="use_sim_time" default="true"/>
    <arg name="headless" default="true"/>
    <arg name="x_pose" default="1.35"/>
    <arg name="y_pose" default="0.0"/>
    
    <include if="$(not $(var headless))" file="$(var gz_sim_launch_path)">
        <arg name="gz_args" value="$(var world_path) -r " /> 
    </include>

    <include if="$(var headless)" file="$(var gz_sim_launch_path)">
        <arg name="gz_args" value="$(var world_path) -r -s" /> 
    </include>
    
    <include file="$(find-pkg-share puzzlebot_description)/launch/puzzlebot_description.launch.xml">
        <arg name="use_sim_time" value="$(var use_sim_time)"/>
        <arg name="rviz" value="false"/>
    </include>

    <include file="$(find-pkg-share gazebo_ros)/launch/gazebo.launch.py">
        <arg name="world" value="$(var world_path)"/>
        <arg name="verbose" value="true"/>
    </include>

    <node pkg="gazebo_ros" exec="spawn_entity.py" output="screen" args="-topic robot_description -entity puzzlebot -x $(var x_pose) -y $(var y_pose)"/>
    
    <node pkg="ros_gz_bridge" exec="parameter_bridge" output="screen">
        <param name="config_file" value="$(var gazebo_bridge_config_path)"/>
    </node> 
    
</launch>
